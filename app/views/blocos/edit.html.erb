<div style="max-width: 600px; margin: 0 auto;">
  <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <h1 style="color: var(--purple-light); font-size: 1.5rem; font-weight: bold;">Editar Bloco</h1>
    <%= link_to "Voltar", blocos_path,
        style: "background-color: var(--bg-row); border: 1px solid var(--border); color: var(--text); padding: 8px 16px; border-radius: 8px; text-decoration: none; font-size: 0.875rem;" %>
  </div>
  <%= render "form", bloco: @bloco %>
</div>