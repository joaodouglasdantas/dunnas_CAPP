<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
  <h1 class="text-2xl font-bold truncate"
      title="<%= @bloco.nome %>"
      style="color: var(--purple-light); max-width: calc(100% - 200px); cursor: help;">
    Bloco <%= @bloco.nome %>
  </h1>
  <div style="display: flex; gap: 8px;">
    <%= link_to "Editar", edit_bloco_path(@bloco),
        style: "background-color: var(--bg-row); border: 1px solid var(--border); color: var(--text); padding: 8px 16px; border-radius: 8px; text-decoration: none; font-size: 0.875rem;",
        onmouseover: "this.style.backgroundColor='var(--purple)'; this.style.borderColor='var(--purple)'",
        onmouseout: "this.style.backgroundColor='var(--bg-row)'; this.style.borderColor='var(--border)'" %>
    <%= link_to "Voltar", blocos_path,
        style: "background-color: var(--bg-row); border: 1px solid var(--border); color: var(--text); padding: 8px 16px; border-radius: 8px; text-decoration: none; font-size: 0.875rem;",
        onmouseover: "this.style.backgroundColor='var(--bg-row)'",
        onmouseout: "this.style.backgroundColor='var(--bg-row)'" %>
  </div>
</div>

<div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;">
  <div style="background-color: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 24px;">
    <p style="color: var(--text-muted); font-size: 0.875rem; margin-bottom: 8px;">Andares</p>
    <p style="color: var(--purple-light); font-size: 2rem; font-weight: bold;"><%= @bloco.quantidade_andares %></p>
  </div>
  <div style="background-color: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 24px;">
    <p style="color: var(--text-muted); font-size: 0.875rem; margin-bottom: 8px;">Unidades por andar</p>
    <p style="color: var(--purple-light); font-size: 2rem; font-weight: bold;"><%= @bloco.unidades_por_andar %></p>
  </div>
  <div style="background-color: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 24px;">
    <p style="color: var(--text-muted); font-size: 0.875rem; margin-bottom: 8px;">Total de unidades</p>
    <p style="color: var(--purple-light); font-size: 2rem; font-weight: bold;"><%= @bloco.unidades.count %></p>
  </div>
</div>

<div style="background-color: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; overflow: hidden;">
  <div style="padding: 16px 20px; border-bottom: 1px solid var(--border);">
    <h2 style="color: var(--text); font-size: 1rem; font-weight: 600;">Unidades</h2>
  </div>
  <table style="width: 100%; border-collapse: collapse;">
    <thead>
      <tr style="border-bottom: 1px solid var(--border);">
        <th style="padding: 12px 16px; text-align: left; color: var(--text-muted); font-size: 0.875rem; font-weight: 500;">Identificação</th>
        <th style="padding: 12px 16px; text-align: left; color: var(--text-muted); font-size: 0.875rem; font-weight: 500;">Andar</th>
        <th style="padding: 12px 16px; text-align: left; color: var(--text-muted); font-size: 0.875rem; font-weight: 500;">Moradores</th>
      </tr>
    </thead>
    <tbody>
      <% @bloco.unidades.order(:numero_andar, :numero_unidade).each do |unidade| %>
        <tr style="border-bottom: 1px solid var(--border);" onmouseover="this.style.backgroundColor='var(--bg-row)'" onmouseout="this.style.backgroundColor='transparent'">
          <td style="padding: 12px 16px; color: var(--text);"><%= unidade.identificacao %></td>
          <td style="padding: 12px 16px; color: var(--text);"><%= unidade.numero_andar %></td>
          <td style="padding: 12px 16px; color: var(--text-muted);">
            <% if unidade.moradores.any? %>
              <%= unidade.moradores.map(&:nome).join(", ") %>
            <% else %>
              <span style="color: var(--text-disabled); font-style: italic;">Sem moradores</span>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>