<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold" style="color: var(--purple-light);">Blocos</h1>
  <%= link_to "Novo Bloco", new_bloco_path,
      class: "px-4 py-2 rounded-lg text-sm text-white font-medium hover:opacity-75 transition",
      style: "background-color: var(--purple);" %>
</div>

<div class="rounded-xl overflow-hidden" style="background-color: var(--bg-card); border: 1px solid var(--border);">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr style="border-bottom: 1px solid var(--border);">
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Nome</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Andares</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Unidades por andar</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Total de unidades</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% @blocos.each do |bloco| %>
          <tr style="border-bottom: 1px solid var(--border);">
            <td class="px-4 py-3 text-sm"
                title="<%= bloco.nome %>"
                style="color: var(--text); cursor: help; max-width: 160px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
              <%= bloco.nome %>
            </td>
            <td class="px-4 py-3 text-sm" style="color: var(--text);"><%= bloco.quantidade_andares %></td>
            <td class="px-4 py-3 text-sm" style="color: var(--text);"><%= bloco.unidades_por_andar %></td>
            <td class="px-4 py-3 text-sm" style="color: var(--text);"><%= bloco.unidades.count %></td>
            <td class="px-4 py-3">
              <div class="flex gap-2 flex-nowrap">
                <%= link_to "Ver", bloco,
                    class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition",
                    style: "background-color: var(--bg-row); border: 1px solid var(--border); color: var(--text);" %>
                <%= link_to "Editar", edit_bloco_path(bloco),
                    class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition",
                    style: "background-color: var(--bg-row); border: 1px solid var(--purple-light); color: var(--purple-light);" %>
                <%= button_to "Remover", bloco_path(bloco), method: :delete,
                    data: { turbo_confirm: "Tem certeza?" },
                    class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition cursor-pointer",
                    style: "background-color: var(--bg-row); border: 1px solid var(--danger); color: var(--danger);" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>