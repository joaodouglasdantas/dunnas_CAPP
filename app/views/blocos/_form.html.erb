<%= form_with model: bloco do |f| %>
  <div style="background-color: var(--bg-card); border: 1px solid var(--border); border-radius: 12px; padding: 24px;">
    <% if bloco.errors.any? %>
      <div style="background-color: var(--error-bg); border: 1px solid var(--danger); color: var(--error-text); padding: 12px 16px; border-radius: 8px; margin-bottom: 16px;">
        <ul style="margin: 0; padding-left: 16px;">
          <% bloco.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div style="margin-bottom: 16px;">
      <%= f.label :nome, style: "display: block; color: var(--text-muted); font-size: 0.875rem; margin-bottom: 6px;" %>
      <%= f.text_field :nome,
          style: "width: 100%; background-color: var(--bg-page); border: 1px solid var(--border); color: var(--text); border-radius: 8px; padding: 10px 14px; outline: none; box-sizing: border-box;" %>
    </div>

    <div style="margin-bottom: 16px;">
      <%= f.label :quantidade_andares, "Quantidade de andares", style: "display: block; color: var(--text-muted); font-size: 0.875rem; margin-bottom: 6px;" %>
      <%= f.number_field :quantidade_andares, min: 1,
          style: "width: 100%; background-color: var(--bg-page); border: 1px solid var(--border); color: var(--text); border-radius: 8px; padding: 10px 14px; outline: none; box-sizing: border-box;" %>
    </div>

    <div style="margin-bottom: 24px;">
      <%= f.label :unidades_por_andar, "Unidades por andar", style: "display: block; color: var(--text-muted); font-size: 0.875rem; margin-bottom: 6px;" %>
      <%= f.number_field :unidades_por_andar, min: 1,
          style: "width: 100%; background-color: var(--bg-page); border: 1px solid var(--border); color: var(--text); border-radius: 8px; padding: 10px 14px; outline: none; box-sizing: border-box;" %>
    </div>

    <%= f.submit bloco.new_record? ? "Criar Bloco" : "Atualizar Bloco",
      style: "background-color: var(--purple); color: white; font-weight: 600; padding: 10px 24px; border-radius: 8px; border: none; cursor: pointer; font-size: 0.875rem;",
      onmouseover: "this.style.backgroundColor='var(--purple)'",
      onmouseout: "this.style.backgroundColor='var(--purple)'" %>
  </div>
<% end %>