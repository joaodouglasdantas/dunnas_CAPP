<div class="max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold" style="color: var(--purple-light);">Abrir Chamado</h1>
    <%= link_to "Voltar", chamados_path,
        class: "px-4 py-2 rounded-lg text-sm hover:opacity-75 transition",
        style: "background-color: var(--bg-row); border: 1px solid var(--border); color: var(--text);" %>
  </div>

  <div class="rounded-xl p-6" style="background-color: var(--bg-card); border: 1px solid var(--border);">
    <%= form_with model: @chamado do |f| %>
      <% if @chamado.errors.any? %>
        <div class="px-4 py-3 rounded-lg mb-4 text-sm" style="background-color: var(--error-bg); border: 1px solid var(--danger); color: var(--error-text);">
          <ul class="list-disc list-inside">
            <% @chamado.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-4">
        <%= f.label :unidade_id, "Unidade", class: "block text-sm mb-2", style: "color: var(--text-muted);" %>
        <%= f.select :unidade_id, @unidades.map { |u| ["#{u.identificacao} — #{u.bloco.nome.truncate(30)}", u.id] },
            { prompt: "Selecione uma unidade" },
            class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: var(--bg-page); border: 1px solid var(--border); color: var(--text);" %>
      </div>

      <div class="mb-4">
        <%= f.label :tipo_chamado_id, "Tipo de Chamado", class: "block text-sm mb-2", style: "color: var(--text-muted);" %>
        <%= f.select :tipo_chamado_id, @tipos.map { |t| [t.titulo.truncate(50), t.id] },
            { prompt: "Selecione um tipo" },
            class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: var(--bg-page); border: 1px solid var(--border); color: var(--text);" %>
      </div>

      <div class="mb-6">
        <%= f.label :descricao, "Descrição", class: "block text-sm mb-2", style: "color: var(--text-muted);" %>
        <%= f.text_area :descricao, rows: 4, placeholder: "Descreva o problema...",
            class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: var(--bg-page); border: 1px solid var(--border); color: var(--text);" %>
      </div>

      <div class="mb-6">
        <%= f.label :anexos, "Anexos (opcional)", class: "block text-sm mb-2", style: "color: var(--text-muted);" %>

        <%= f.file_field :anexos, multiple: true, accept: "image/*,video/*",
            id: "chamado_anexos_input",
            onchange: "previewChamadoAnexos(this)",
            class: "hidden" %>

        <button type="button"
            id="btn_escolher_arquivos"
            onclick="document.getElementById('chamado_anexos_input').click()"
            class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium hover:opacity-75 transition"
            style="background-color: var(--bg-page); border: 1px solid var(--border); color: var(--text-muted);">
          📎 Escolher arquivos
        </button>

        <p id="anexo_aviso" class="text-xs mt-1" style="color: var(--text-subtle);">Máximo de 2 anexos.</p>

        <div id="chamado_preview_container" class="flex flex-wrap gap-2 mt-2"></div>
      </div>

      <script>
        const MAX_ANEXOS = 2;
        const dt = new DataTransfer();

        function previewChamadoAnexos(input) {
          const container = document.getElementById('chamado_preview_container');
          const aviso = document.getElementById('anexo_aviso');
          const btn = document.getElementById('btn_escolher_arquivos');

          Array.from(input.files).forEach((file) => {
            if (dt.files.length >= MAX_ANEXOS) return;
            dt.items.add(file);
          });

          input.files = dt.files;

          if (dt.files.length >= MAX_ANEXOS) {
            btn.style.display = 'none';
            aviso.textContent = 'Limite de 2 anexos atingido.';
            aviso.style.color = '#f87171';
          }

          container.innerHTML = '';
          Array.from(dt.files).forEach((file, index) => {
            const wrapper = document.createElement('div');
            wrapper.style.cssText = 'position: relative; display: inline-block;';

            if (file.type.startsWith('image/')) {
              const reader = new FileReader();
              reader.onload = (e) => {
                const img = document.createElement('img');
                img.src = e.target.result;
                img.style.cssText = 'max-width: 120px; border-radius: 8px; border: 1px solid var(--border); display: block;';
                wrapper.appendChild(img);
              };
              reader.readAsDataURL(file);
            } else {
              const div = document.createElement('div');
              div.style.cssText = 'background-color: var(--bg-row); border: 1px solid var(--border); border-radius: 8px; padding: 8px 12px; font-size: 0.75rem; color: var(--text-muted);';
              div.textContent = '🎥 ' + file.name;
              wrapper.appendChild(div);
            }

            const btnRemover = document.createElement('button');
            btnRemover.textContent = '✕';
            btnRemover.style.cssText = 'position: absolute; top: -6px; right: -6px; background-color: var(--danger); color: white; border: none; border-radius: 50%; width: 18px; height: 18px; font-size: 10px; cursor: pointer;';
            btnRemover.onclick = (e) => {
              e.preventDefault();
              const newDt = new DataTransfer();
              Array.from(dt.files).forEach((f, i) => {
                if (i !== index) newDt.items.add(f);
              });
              while (dt.items.length > 0) dt.items.remove(0);
              Array.from(newDt.files).forEach(f => dt.items.add(f));
              input.files = dt.files;

              if (dt.files.length < MAX_ANEXOS) {
                btn.style.display = '';
                aviso.textContent = 'Máximo de 2 anexos.';
                aviso.style.color = 'var(--text-subtle)';
              }

              wrapper.remove();
            };

            wrapper.appendChild(btnRemover);
            container.appendChild(wrapper);
          });
        }
      </script>

      <%= f.submit "Abrir Chamado",
          class: "px-6 py-2 rounded-lg text-sm text-white font-medium hover:opacity-75 transition cursor-pointer",
          style: "background-color: var(--purple); border: none;" %>
    <% end %>
  </div>
</div>