<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold" style="color: #a78bfa;">Chamados</h1>
  <% if current_user.morador? %>
    <%= link_to "Abrir Novo Chamado", new_chamado_path,
        class: "px-4 py-2 rounded-lg text-sm text-white font-medium hover:opacity-75 transition",
        style: "background-color: #7c3aed;" %>
  <% end %>
</div>

<div class="rounded-xl overflow-hidden" style="background-color: #1a2e4a; border: 1px solid #2d4a6b;">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr style="border-bottom: 1px solid #2d4a6b;">
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: #94a3b8;">Unidade</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: #94a3b8;">Tipo</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: #94a3b8;">Status</th>
          <th class="px-4 py-3 text-left text-sm font-medium hidden md:table-cell" style="color: #94a3b8;">Descrição</th>
          <th class="px-4 py-3 text-left text-sm font-medium hidden md:table-cell" style="color: #94a3b8;">Aberto em</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: #94a3b8;">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% @chamados.each do |chamado| %>
          <tr style="border-bottom: 1px solid #2d4a6b;">
            <td class="px-4 py-3 text-sm" style="color: #f1f5f9;"><%= chamado.unidade.identificacao %></td>
            <td class="px-4 py-3 text-sm" style="color: #f1f5f9;"><%= chamado.tipo_chamado.titulo %></td>
            <td class="px-4 py-3">
              <span class="text-xs px-2 py-1 rounded-full" style="background-color: #2d4a6b; color: #a78bfa;"><%= chamado.status_chamado.nome %></span>
            </td>
            <td class="px-4 py-3 text-sm hidden md:table-cell" style="color: #94a3b8;"><%= truncate(chamado.descricao, length: 50) %></td>
            <td class="px-4 py-3 text-sm hidden md:table-cell" style="color: #94a3b8;"><%= chamado.created_at.strftime("%d/%m/%Y %H:%M") %></td>
            <td class="px-4 py-3">
              <div class="flex gap-2">
                <%= link_to "Ver", chamado,
                  class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition",
                  style: "background-color: #1e3352; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
                <% if current_user.administrador? || current_user.colaborador? || chamado.usuario == current_user %>
                  <%= link_to "Editar", edit_chamado_path(chamado),
                      class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition",
                      style: "background-color: #1e3352; border: 1px solid #a78bfa; color: #a78bfa;" %>
                <% end %>
                <% if current_user.administrador? %>
                  <%= button_to "Remover", chamado_path(chamado), method: :delete,
                      data: { turbo_confirm: "Tem certeza?" },
                      class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition cursor-pointer",
                      style: "background-color: #1e3352; border: 1px solid #ef4444; color: #ef4444;" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>