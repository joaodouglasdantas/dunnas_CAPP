<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold" style="color: #a78bfa;">
    Chamados
    <% if @mostrando_arquivados %>
      <span class="text-sm font-normal ml-2 px-2 py-1 rounded-full"
            title="Estes são chamados que já foram finalizados e movidos para o histórico."
            style="background-color: #2d4a6b; color: #94a3b8; cursor: help;"> Arquivados
      </span>
    <% end %>
  </h1>
  <div class="flex gap-2">
    <% if @mostrando_arquivados %>
      <%= link_to "Ver Ativos", chamados_path,
          class: "px-4 py-2 rounded-lg text-sm hover:opacity-75 transition",
          style: "background-color: #1e3352; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
    <% else %>
      <%= link_to "Ver Arquivados", chamados_path(arquivados: true),
          class: "px-4 py-2 rounded-lg text-sm hover:opacity-75 transition",
          style: "background-color: #1e3352; border: 1px solid #2d4a6b; color: #94a3b8;" %>
    <% end %>
    <% if current_user.morador? %>
      <%= link_to "Abrir Novo Chamado", new_chamado_path,
          class: "px-4 py-2 rounded-lg text-sm text-white font-medium hover:opacity-75 transition",
          style: "background-color: #7c3aed;" %>
    <% end %>
  </div>
</div>

<div class="rounded-xl p-4 mb-6" style="background-color: #1a2e4a; border: 1px solid #2d4a6b;">
  <%= form_with url: chamados_path, method: :get, local: true do |f| %>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
      <div>
        <label class="block text-xs mb-1" style="color: #94a3b8;">Status</label>
        <%= select_tag :status_id,
            options_for_select(@status_list.map { |s| [s.nome.truncate(40), s.id] }, params[:status_id]),
            prompt: "Todos",
            class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
      </div>
      <div>
        <label class="block text-xs mb-1" style="color: #94a3b8;">Tipo</label>
        <%= select_tag :tipo_id,
            options_for_select(@tipos_list.map { |t| [t.titulo.truncate(40), t.id] }, params[:tipo_id]),
            prompt: "Todos",
            class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
      </div>
      <% if current_user.administrador? %>
        <div>
          <label class="block text-xs mb-1" style="color: #94a3b8;">Bloco</label>
          <%= select_tag :bloco_id,
              options_for_select(@blocos_list.map { |b| [b.nome.truncate(25), b.id] }, params[:bloco_id]),
              prompt: "Todos",
              class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
              style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
        </div>
      <% end %>
      <div>
        <label class="block text-xs mb-1" style="color: #94a3b8;">Período</label>
        <%= select_tag :periodo,
            options_for_select([["Todos", ""], ["Hoje", "hoje"], ["Última semana", "semana"], ["Último mês", "mes"]], params[:periodo]),
            class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
      </div>
    </div>
    <div class="flex gap-2 mt-3">
      <%= f.submit "Filtrar",
          class: "px-4 py-2 rounded-lg text-sm text-white font-medium cursor-pointer hover:opacity-75 transition",
          style: "background-color: #7c3aed; border: none;" %>
      <%= link_to "Limpar", chamados_path,
          class: "px-4 py-2 rounded-lg text-sm hover:opacity-75 transition",
          style: "background-color: #1e3352; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
    </div>
  <% end %>
</div>

<div class="rounded-xl overflow-hidden" style="background-color: #1a2e4a; border: 1px solid #2d4a6b;">
  <div class="overflow-x-auto">
    <table class="w-full table-fixed">
      <thead>
        <tr style="border-bottom: 1px solid #2d4a6b;">
          <th class="px-4 py-3 text-left text-sm font-medium w-32" style="color: #94a3b8;">Unidade</th>
          <th class="px-4 py-3 text-left text-sm font-medium w-32" style="color: #94a3b8;">Tipo</th>
          <th class="px-4 py-3 text-left text-sm font-medium w-32" style="color: #94a3b8;">Status</th>
          <th class="px-4 py-3 text-left text-sm font-medium hidden md:table-cell" style="color: #94a3b8;">Descrição</th>
          <th class="px-4 py-3 text-left text-sm font-medium hidden md:table-cell w-36" style="color: #94a3b8;">Aberto em</th>
          <th class="px-4 py-3 text-left text-sm font-medium w-44" style="color: #94a3b8;">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% @chamados.each do |chamado| %>
          <tr style="border-bottom: 1px solid #2d4a6b;">
            <td class="px-4 py-3 text-sm w-32" style="color: #f1f5f9;">
              <span class="block truncate"
                    style="cursor: help;"
                    title="<%= chamado.unidade.identificacao %> — <%= chamado.unidade.bloco.nome %>">
                <%= truncate("#{chamado.unidade.identificacao} — #{chamado.unidade.bloco.nome}", length: 18) %>
              </span>
            </td>
            <td class="px-4 py-3 text-sm w-32" style="color: #f1f5f9;">
              <span class="block truncate"
                    style="cursor: help;"
                    title="<%= chamado.tipo_chamado.titulo %>">
                <%= truncate(chamado.tipo_chamado.titulo, length: 20) %>
              </span>
            </td>
            <td class="px-4 py-3 w-32">
              <span class="text-xs px-2 py-1 rounded-full inline-block truncate max-w-full"
                    title="<%= chamado.status_chamado.nome %>"
                    style="background-color: #2d4a6b; color: #a78bfa; cursor: help;">
                <%= truncate(chamado.status_chamado.nome, length: 18) %>
              </span>
            </td>
            <td class="px-4 py-3 text-sm hidden md:table-cell"
                title="<%= chamado.descricao %>"
                style="color: #94a3b8; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; cursor: help;">
              <%= chamado.descricao %>
            </td>
            <td class="px-4 py-3 text-sm hidden md:table-cell w-36" style="color: #94a3b8;">
              <%= chamado.created_at.strftime("%d/%m/%Y %H:%M") %>
            </td>
            <td class="px-4 py-3 w-44">
              <div class="flex gap-2 flex-wrap">
                <%= link_to "Ver", chamado,
                  class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition",
                  style: "background-color: #1e3352; border: 1px solid #2d4a6b; color: #f1f5f9;" %>

                <% if current_user.administrador? ||
                  (current_user.colaborador? && current_user.tipos_chamado_responsavel.include?(chamado.tipo_chamado)) ||
                  (chamado.usuario == current_user && chamado.status_chamado.padrao?) %>
                  <%= link_to "Editar", edit_chamado_path(chamado),
                    class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition",
                    style: "background-color: #1e3352; border: 1px solid #a78bfa; color: #a78bfa;" %>
                <% end %>

                <% if current_user.administrador? %>
                  <%= button_to "Remover", chamado_path(chamado), method: :delete,
                      data: { turbo_confirm: "Tem certeza?" },
                      class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition cursor-pointer",
                      style: "background-color: #1e3352; border: 1px solid #ef4444; color: #ef4444;" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>