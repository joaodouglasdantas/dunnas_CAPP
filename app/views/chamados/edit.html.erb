<div class="max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold" style="color: #a78bfa;">
      <% if current_user.administrador? || current_user.colaborador? %>
        Atualizar Status — Chamado #<%= @chamado.id %>
      <% else %>
        Editar Chamado #<%= @chamado.id %>
      <% end %>
    </h1>
    <%= link_to "Voltar", chamado_path(@chamado),
        class: "px-4 py-2 rounded-lg text-sm hover:opacity-75 transition",
        style: "background-color: #1e3352; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
  </div>

  <div class="rounded-xl p-6" style="background-color: #1a2e4a; border: 1px solid #2d4a6b;">
    <%= form_with model: @chamado do |f| %>

      <% if current_user.administrador? || current_user.colaborador? %>
        <div class="mb-6">
          <%= f.label :status_chamado_id, "Status", class: "block text-sm mb-2", style: "color: #94a3b8;" %>
          <%= f.select :status_chamado_id, @status_list.map { |s| [s.nome, s.id] },
              {},
              class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
              style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
        </div>
      <% end %>

      <% if current_user.morador? && @chamado.status_chamado.padrao? %>
        <div class="mb-6">
          <%= f.label :unidade_id, "Unidade", class: "block text-sm mb-2", style: "color: #94a3b8;" %>
          <%= f.select :unidade_id, @unidades.map { |u| [u.identificacao, u.id] },
              {},
              class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
              style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
        </div>

        <div class="mb-6">
          <%= f.label :tipo_chamado_id, "Tipo", class: "block text-sm mb-2", style: "color: #94a3b8;" %>
          <%= f.select :tipo_chamado_id, @tipos.map { |t| [t.titulo, t.id] },
              {},
              class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
              style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
        </div>
      <% end %>

      <div class="mb-6">
        <%= f.label :descricao, "Descrição", class: "block text-sm mb-2", style: "color: #94a3b8;" %>
        <%= f.text_area :descricao,
            class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9; min-height: 100px;" %>
      </div>

      <% if current_user.morador? && @chamado.status_chamado.padrao? %>
        <div class="mb-6">
          <% if @chamado.anexos.attached? %>
            <p class="text-sm mb-3" style="color: #94a3b8;">Anexos atuais:</p>
            <div class="flex flex-col gap-2 mb-4">
              <% @chamado.anexos.each do |anexo| %>
                <div class="flex items-center justify-between px-3 py-2 rounded-lg" style="background-color: #152338; border: 1px solid #2d4a6b;">
                  <span class="text-sm" style="color: #f1f5f9;"><%= anexo.filename %></span>
                  <%= link_to "Remover",
                      remover_anexo_chamado_path(@chamado, anexo_id: anexo.id),
                      data: { turbo_method: :delete, turbo_confirm: "Remover este anexo?" },
                      class: "text-xs px-2 py-1 rounded-lg hover:opacity-75 transition",
                      style: "border: 1px solid #ef4444; color: #ef4444;" %>
                </div>
              <% end %>
            </div>
          <% end %>

          <%= f.label :anexos, "Adicionar anexos", class: "block text-sm mb-2", style: "color: #94a3b8;" %>

          <%= f.file_field :anexos, multiple: true, accept: "image/*,video/*",
              id: "edit_anexos_input",
              onchange: "previewEditAnexos(this)",
              class: "hidden" %>

          <button type="button"
              id="btn_edit_anexos"
              onclick="document.getElementById('edit_anexos_input').click()"
              class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium hover:opacity-75 transition"
              style="background-color: #152338; border: 1px solid #2d4a6b; color: #94a3b8;">
            📎 Escolher arquivos
          </button>

          <p id="edit_anexo_aviso" class="text-xs mt-1" style="color: #64748b;">Máximo de 2 anexos.</p>
          <div id="edit_preview_container" class="flex flex-wrap gap-2 mt-2"></div>
        </div>
      <% end %>

      <%= f.submit "Atualizar",
          class: "px-6 py-2 rounded-lg text-sm text-white font-medium hover:opacity-75 transition cursor-pointer",
          style: "background-color: #7c3aed; border: none;" %>
    <% end %>
  </div>
</div>

<script>
  const MAX_ANEXOS_EDIT = 2;
  const dtEdit = new DataTransfer();

  function previewEditAnexos(input) {
    const container = document.getElementById('edit_preview_container');
    const aviso = document.getElementById('edit_anexo_aviso');
    const btn = document.getElementById('btn_edit_anexos');

    Array.from(input.files).forEach((file) => {
      if (dtEdit.files.length >= MAX_ANEXOS_EDIT) return;
      dtEdit.items.add(file);
    });

    input.files = dtEdit.files;

    if (dtEdit.files.length >= MAX_ANEXOS_EDIT) {
      btn.style.display = 'none';
      aviso.textContent = 'Limite de 2 anexos atingido.';
      aviso.style.color = '#f87171';
    }

    container.innerHTML = '';
    Array.from(dtEdit.files).forEach((file, index) => {
      const wrapper = document.createElement('div');
      wrapper.style.cssText = 'position: relative; display: inline-block;';

      if (file.type.startsWith('image/')) {
        const reader = new FileReader();
        reader.onload = (e) => {
          const img = document.createElement('img');
          img.src = e.target.result;
          img.style.cssText = 'max-width: 120px; border-radius: 8px; border: 1px solid #2d4a6b; display: block;';
          wrapper.appendChild(img);
        };
        reader.readAsDataURL(file);
      } else {
        const div = document.createElement('div');
        div.style.cssText = 'background-color: #1e3352; border: 1px solid #2d4a6b; border-radius: 8px; padding: 8px 12px; font-size: 0.75rem; color: #94a3b8;';
        div.textContent = '🎥 ' + file.name;
        wrapper.appendChild(div);
      }

      const btnRemover = document.createElement('button');
      btnRemover.textContent = '✕';
      btnRemover.style.cssText = 'position: absolute; top: -6px; right: -6px; background-color: #ef4444; color: white; border: none; border-radius: 50%; width: 18px; height: 18px; font-size: 10px; cursor: pointer;';
      btnRemover.onclick = (e) => {
        e.preventDefault();
        const newDt = new DataTransfer();
        Array.from(dtEdit.files).forEach((f, i) => {
          if (i !== index) newDt.items.add(f);
        });
        while (dtEdit.items.length > 0) dtEdit.items.remove(0);
        Array.from(newDt.files).forEach(f => dtEdit.items.add(f));
        input.files = dtEdit.files;

        if (dtEdit.files.length < MAX_ANEXOS_EDIT) {
          btn.style.display = '';
          aviso.textContent = 'Máximo de 2 anexos.';
          aviso.style.color = '#64748b';
        }

        wrapper.remove();
      };

      wrapper.appendChild(btnRemover);
      container.appendChild(wrapper);
    });
  }
</script>
