<style>
  .descricao-scroll {
    max-height: 220px;
    min-height: 0;
    overflow-y: auto;
  }

  .comentarios-scroll {
    max-height: 400px;
    overflow-y: auto;
  }

  .comentarios-scroll::-webkit-scrollbar,
  .descricao-scroll::-webkit-scrollbar {
    width: 6px;
  }

  .comentarios-scroll::-webkit-scrollbar-track,
  .descricao-scroll::-webkit-scrollbar-track {
    background: transparent;
  }

  .comentarios-scroll::-webkit-scrollbar-thumb,
  .descricao-scroll::-webkit-scrollbar-thumb {
    background-color: #2d4a6b;
    border-radius: 999px;
  }

  .comentarios-scroll::-webkit-scrollbar-thumb:hover,
  .descricao-scroll::-webkit-scrollbar-thumb:hover {
    background-color: #7c3aed;
  }

  .anexo-img {
    width: 150px;
    height: 150px;
    object-fit: cover;
    border-radius: 8px;
    display: block;
  }

  .comentario-anexo-img {
    width: 120px;
    height: 120px;
    object-fit: cover;
    border-radius: 8px;
    display: block;
  }
</style>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold" style="color: #a78bfa;">Chamado #<%= @chamado.id %></h1>
  <div class="flex gap-2">
    <% if current_user.administrador? || (current_user.colaborador? && current_user.tipos_chamado_responsavel.include?(@chamado.tipo_chamado)) %>
      <%= link_to "Atualizar Status", edit_chamado_path(@chamado),
          class: "px-4 py-2 rounded-lg text-sm text-white font-medium hover:opacity-75 transition",
          style: "background-color: #7c3aed;" %>
    <% elsif @chamado.usuario == current_user && @chamado.status_chamado.padrao? %>
      <%= link_to "Editar", edit_chamado_path(@chamado),
          class: "px-4 py-2 rounded-lg text-sm font-medium hover:opacity-75 transition",
          style: "background-color: #1e3352; border: 1px solid #a78bfa; color: #a78bfa;" %>
    <% end %>
    <%= link_to "Voltar", chamados_path,
        class: "px-4 py-2 rounded-lg text-sm hover:opacity-75 transition",
        style: "background-color: #1e3352; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
  </div>
</div>

<div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
  <div class="rounded-xl p-6" style="background-color: #1a2e4a; border: 1px solid #2d4a6b;">
    <h2 class="text-base font-semibold mb-4" style="color: #f1f5f9;">Informações</h2>
    <div class="space-y-3">
      <div>
        <p class="text-xs mb-1" style="color: #94a3b8;">Unidade</p>
        <p class="text-sm" style="color: #f1f5f9;"><%= @chamado.unidade.identificacao %></p>
      </div>
      <div>
        <p class="text-xs mb-1" style="color: #94a3b8;">Tipo</p>
        <p class="text-sm" style="color: #f1f5f9;"><%= @chamado.tipo_chamado.titulo %></p>
      </div>
      <div>
        <p class="text-xs mb-1" style="color: #94a3b8;">Status</p>
        <span class="text-xs px-2 py-1 rounded-full" style="background-color: #2d4a6b; color: #a78bfa;"><%= @chamado.status_chamado.nome %></span>
      </div>
      <div>
        <p class="text-xs mb-1" style="color: #94a3b8;">Aberto por</p>
        <p class="text-sm" style="color: #f1f5f9;"><%= @chamado.usuario.nome %></p>
      </div>
      <div>
        <p class="text-xs mb-1" style="color: #94a3b8;">Aberto em</p>
        <p class="text-sm" style="color: #f1f5f9;"><%= @chamado.created_at.strftime("%d/%m/%Y %H:%M") %></p>
      </div>
      <% if @chamado.finalizado_em %>
        <div>
          <p class="text-xs mb-1" style="color: #94a3b8;">Finalizado em</p>
          <p class="text-sm" style="color: #f1f5f9;"><%= @chamado.finalizado_em.strftime("%d/%m/%Y %H:%M") %></p>
        </div>
      <% end %>
    </div>
  </div>

  <div class="rounded-xl p-6 flex flex-col" style="background-color: #1a2e4a; border: 1px solid #2d4a6b;">
    <h2 class="text-base font-semibold mb-4" style="color: #f1f5f9;">Descrição</h2>
    <div class="descricao-scroll">
      <p class="text-sm" style="color: #94a3b8;"><%= @chamado.descricao %></p>
    </div>
  </div>

  <% if @chamado.anexos.attached? %>
    <div class="rounded-xl p-6" style="background-color: #1a2e4a; border: 1px solid #2d4a6b;">
      <p class="text-xs mb-3" style="color: #94a3b8;">Anexos</p>
      <div class="flex flex-wrap gap-2">
        <% @chamado.anexos.each do |anexo| %>
          <% if anexo.image? %>
            <%= link_to url_for(anexo), target: "_blank" do %>
              <%= image_tag url_for(anexo), class: "anexo-img hover:opacity-75 transition" %>
            <% end %>
          <% elsif anexo.video? %>
            <video class="rounded-lg" width="150" height="150" style="object-fit: cover;" controls>
              <source src="<%= url_for(anexo) %>">
            </video>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>
</div>

<div class="rounded-xl overflow-hidden mb-6" style="background-color: #1a2e4a; border: 1px solid #2d4a6b;">
  <div class="px-6 py-4" style="border-bottom: 1px solid #2d4a6b;">
    <h2 class="text-base font-semibold" style="color: #f1f5f9;">Comentários</h2>
  </div>

  <div class="comentarios-scroll">
    <% if @comentarios.any? %>
      <% @comentarios.each do |comentario| %>
        <div class="px-6 py-4" style="border-bottom: 1px solid #2d4a6b;">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-sm font-medium" style="color: #a78bfa;"><%= comentario.usuario.nome %></span>
            <span class="text-xs" style="color: #94a3b8;"><%= comentario.created_at.strftime("%d/%m/%Y %H:%M") %></span>
          </div>
          <p class="text-sm" style="color: #f1f5f9;"><%= comentario.mensagem %></p>
          <% if comentario.anexos.attached? %>
            <div class="flex flex-wrap gap-2 mt-2">
              <% comentario.anexos.each do |anexo| %>
                <% if anexo.image? %>
                  <%= link_to url_for(anexo), target: "_blank" do %>
                    <%= image_tag url_for(anexo), class: "comentario-anexo-img hover:opacity-75 transition" %>
                  <% end %>
                <% elsif anexo.video? %>
                  <video class="rounded-lg" width="120" height="120" style="object-fit: cover;" controls>
                    <source src="<%= url_for(anexo) %>">
                  </video>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <p class="px-6 py-4 text-sm" style="color: #94a3b8;">Nenhum comentário ainda.</p>
    <% end %>
  </div>

  <div class="px-6 py-4" style="border-top: 1px solid #2d4a6b;">
    <h3 class="text-sm font-semibold mb-3" style="color: #f1f5f9;">Adicionar Comentário</h3>
    <%= form_with model: [@chamado, @comentario] do |f| %>
      <div class="mb-3">
        <%= f.text_area :mensagem, rows: 3, placeholder: "Digite seu comentário...",
            class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
      </div>
      <div class="mb-3">
        <%= f.file_field :anexos, multiple: true, accept: "image/*,video/*",
            class: "hidden",
            id: "anexos_input",
            onchange: "previewAnexos(this)" %>

        <button type="button"
            id="btn_anexos_comentario"
            onclick="document.getElementById('anexos_input').click()"
            class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium hover:opacity-75 transition"
            style="background-color: #152338; border: 1px solid #2d4a6b; color: #94a3b8;">
          📎 Escolher arquivos
        </button>

        <p id="anexo_aviso_comentario" class="text-xs mt-1" style="color: #64748b;">Máximo de 2 anexos.</p>
        <div id="preview_container" class="flex flex-wrap gap-2 mt-2"></div>
      </div>
      <%= f.submit "Comentar",
          class: "px-4 py-2 rounded-lg text-sm text-white font-medium hover:opacity-75 transition cursor-pointer",
          style: "background-color: #7c3aed; border: none;" %>
    <% end %>
  </div>

  <script>
    const MAX_ANEXOS_COM = 2;
    const dtCom = new DataTransfer();

    function previewAnexos(input) {
      const container = document.getElementById('preview_container');
      const aviso = document.getElementById('anexo_aviso_comentario');
      const btn = document.getElementById('btn_anexos_comentario');

      Array.from(input.files).forEach((file) => {
        if (dtCom.files.length >= MAX_ANEXOS_COM) return;
        dtCom.items.add(file);
      });

      input.files = dtCom.files;

      if (dtCom.files.length >= MAX_ANEXOS_COM) {
        btn.style.display = 'none';
        aviso.textContent = 'Limite de 2 anexos atingido.';
        aviso.style.color = '#f87171';
      }

      container.innerHTML = '';
      Array.from(dtCom.files).forEach((file, index) => {
        const wrapper = document.createElement('div');
        wrapper.style.cssText = 'position: relative; display: inline-block;';

        if (file.type.startsWith('image/')) {
          const reader = new FileReader();
          reader.onload = (e) => {
            const img = document.createElement('img');
            img.src = e.target.result;
            img.style.cssText = 'width: 120px; height: 120px; object-fit: cover; border-radius: 8px; border: 1px solid #2d4a6b; display: block;';
            wrapper.appendChild(img);
          };
          reader.readAsDataURL(file);
        } else {
          const div = document.createElement('div');
          div.style.cssText = 'background-color: #1e3352; border: 1px solid #2d4a6b; border-radius: 8px; padding: 8px 12px; font-size: 0.75rem; color: #94a3b8;';
          div.textContent = '🎥 ' + file.name;
          wrapper.appendChild(div);
        }

        const btnRemover = document.createElement('button');
        btnRemover.textContent = '✕';
        btnRemover.style.cssText = 'position: absolute; top: -6px; right: -6px; background-color: #ef4444; color: white; border: none; border-radius: 50%; width: 18px; height: 18px; font-size: 10px; cursor: pointer;';
        btnRemover.onclick = (e) => {
          e.preventDefault();
          const newDt = new DataTransfer();
          Array.from(dtCom.files).forEach((f, i) => {
            if (i !== index) newDt.items.add(f);
          });
          while (dtCom.items.length > 0) dtCom.items.remove(0);
          Array.from(newDt.files).forEach(f => dtCom.items.add(f));
          input.files = dtCom.files;

          if (dtCom.files.length < MAX_ANEXOS_COM) {
            btn.style.display = '';
            aviso.textContent = 'Máximo de 2 anexos.';
            aviso.style.color = '#64748b';
          }

          wrapper.remove();
        };

        wrapper.appendChild(btnRemover);
        container.appendChild(wrapper);
      });
    }
  </script>
</div>
