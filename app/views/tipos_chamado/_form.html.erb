<%= form_with model: tipo_chamado, url: tipo_chamado.new_record? ? tipos_chamado_index_path : tipos_chamado_path(tipo_chamado) do |f| %>
  <% if tipo_chamado.errors.any? %>
    <div class="px-4 py-3 rounded-lg mb-4 text-sm" style="background-color: var(--error-bg); border: 1px solid var(--danger); color: var(--error-text);">
      <ul class="list-disc list-inside">
        <% tipo_chamado.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-4">
    <%= f.label :titulo, "Título", class: "block text-sm mb-2", style: "color: var(--text-muted);" %>
    <%= f.text_field :titulo, class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
        style: "background-color: var(--bg-page); border: 1px solid var(--border); color: var(--text);" %>
  </div>
  <div class="mb-6">
    <%= f.label :sla_horas, "SLA (horas)", class: "block text-sm mb-2", style: "color: var(--text-muted);" %>
    <%= f.number_field :sla_horas, min: 1, class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
        style: "background-color: var(--bg-page); border: 1px solid var(--border); color: var(--text);" %>
  </div>

  <%= f.submit class: "px-6 py-2 rounded-lg text-sm text-white font-medium hover:opacity-75 transition cursor-pointer",
      style: "background-color: var(--purple); border: none;" %>
<% end %>