<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold" style="color: var(--purple-light);">Tipos de Chamado</h1>
  <%= link_to "Novo Tipo", new_tipos_chamado_path,
      class: "px-4 py-2 rounded-lg text-sm text-white font-medium hover:opacity-75 transition",
      style: "background-color: var(--purple);" %>
</div>

<div class="rounded-xl overflow-hidden" style="background-color: var(--bg-card); border: 1px solid var(--border);">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr style="border-bottom: 1px solid var(--border);">
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Título</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">SLA (horas)</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% @tipos_chamado.each do |tipo| %>
          <tr style="border-bottom: 1px solid var(--border);">
            <td class="px-4 py-3 text-sm"
                title="<%= tipo.titulo %>"
                style="color: var(--text); cursor: help; max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
              <%= tipo.titulo %>
            </td>
            <td class="px-4 py-3 text-sm" style="color: var(--text);"><%= tipo.sla_horas %>h</td>
            <td class="px-4 py-3">
              <div class="flex gap-2 flex-nowrap">
                <%= link_to "Editar", edit_tipos_chamado_path(tipo),
                    class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition",
                    style: "background-color: var(--bg-row); border: 1px solid var(--purple-light); color: var(--purple-light);" %>
                <%= button_to "Remover", tipos_chamado_path(tipo), method: :delete,
                    data: { turbo_confirm: "Tem certeza?" },
                    class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition cursor-pointer",
                    style: "background-color: var(--bg-row); border: 1px solid var(--danger); color: var(--danger);" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>