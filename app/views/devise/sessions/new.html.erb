<div class="min-h-screen flex items-center justify-center px-4" style="background-color: var(--bg-page);">
  <div class="w-full max-w-md rounded-xl p-8" style="background-color: var(--bg-card); border: 1px solid var(--border);">

    <div class="text-center mb-8">
      <div class="flex justify-center mb-6">
        <%= render "shared/logo_login" %>
      </div>
      <p class="text-sm" style="color: var(--text-muted);">Sistema de Gerenciamento de Condomínios</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :email, class: "block text-sm mb-2", style: "color: var(--text-muted);" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: var(--bg-page); border: 1px solid var(--border); color: var(--text);" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "Senha", class: "block text-sm mb-2", style: "color: var(--text-muted);" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: var(--bg-page); border: 1px solid var(--border); color: var(--text);" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-6 flex items-center gap-2">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, "Lembrar de mim", class: "text-sm", style: "color: var(--text-muted);" %>
        </div>
      <% end %>

      <%= f.submit "Entrar",
          class: "w-full py-3 rounded-lg text-sm text-white font-semibold hover:opacity-75 transition cursor-pointer",
          style: "background-color: var(--purple); border: none;" %>
    <% end %>
  </div>
</div>