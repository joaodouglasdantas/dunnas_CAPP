<div class="min-h-screen flex items-center justify-center px-4" style="background-color: #152338;">
  <div class="w-full max-w-md rounded-xl p-8" style="background-color: #1a2e4a; border: 1px solid #2d4a6b;">

    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold mb-1" style="color: #a78bfa;">Capp</h1>
      <p class="text-sm" style="color: #94a3b8;">Sistema de Gerenciamento de Condomínios</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <div class="mb-4">
        <%= f.label :email, class: "block text-sm mb-2", style: "color: #94a3b8;" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email",
            class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
      </div>

      <div class="mb-4">
        <%= f.label :password, "Senha", class: "block text-sm mb-2", style: "color: #94a3b8;" %>
        <%= f.password_field :password, autocomplete: "current-password",
            class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="mb-6 flex items-center gap-2">
          <%= f.check_box :remember_me %>
          <%= f.label :remember_me, "Lembrar de mim", class: "text-sm", style: "color: #94a3b8;" %>
        </div>
      <% end %>

      <%= f.submit "Entrar",
          class: "w-full py-3 rounded-lg text-sm text-white font-semibold hover:opacity-75 transition cursor-pointer",
          style: "background-color: #7c3aed; border: none;" %>
    <% end %>
  </div>
</div>