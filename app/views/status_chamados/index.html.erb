<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold" style="color: var(--purple-light);">Status de Chamado</h1>
  <%= link_to "Novo Status", new_status_chamado_path,
      class: "px-4 py-2 rounded-lg text-sm text-white font-medium hover:opacity-75 transition",
      style: "background-color: var(--purple);" %>
</div>

<div class="rounded-xl overflow-hidden" style="background-color: var(--bg-card); border: 1px solid var(--border);">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr style="border-bottom: 1px solid var(--border);">
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Nome</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Padrão</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% @status_chamados.each do |status| %>
          <tr style="border-bottom: 1px solid var(--border);">
            <td class="px-4 py-3 text-sm"
                title="<%= status.nome %>"
                style="color: var(--text); max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; cursor: help;">
              <%= status.nome %>
            </td>
            <td class="px-4 py-3">
              <% if status.padrao %>
                <span class="text-xs px-2 py-1 rounded-full" style="background-color: var(--success-bg); color: var(--success-text);">Sim</span>
              <% else %>
                <span class="text-xs px-2 py-1 rounded-full" style="background-color: var(--border); color: var(--text-muted);">Não</span>
              <% end %>
            </td>
            <td class="px-4 py-3">
              <div class="flex gap-2 flex-nowrap">
                <% if status.nome.downcase == "concluído" %>
                  <span class="text-xs px-3 py-1 rounded-lg" style="color: var(--text-subtle); border: 1px solid var(--border);">Protegido</span>
                <% else %>
                  <%= link_to "Editar", edit_status_chamado_path(status),
                      class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition",
                      style: "background-color: var(--bg-row); border: 1px solid var(--purple-light); color: var(--purple-light);" %>
                  <%= button_to "Remover", status_chamado_path(status), method: :delete,
                      data: { turbo_confirm: "Tem certeza?" },
                      class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition cursor-pointer",
                      style: "background-color: var(--bg-row); border: 1px solid var(--danger); color: var(--danger);" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>