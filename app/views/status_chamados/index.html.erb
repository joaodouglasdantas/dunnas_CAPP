<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold" style="color: #a78bfa;">Status de Chamado</h1>
  <%= link_to "Novo Status", new_status_chamado_path,
      class: "px-4 py-2 rounded-lg text-sm text-white font-medium hover:opacity-75 transition",
      style: "background-color: #7c3aed;" %>
</div>

<div class="rounded-xl overflow-hidden" style="background-color: #1a2e4a; border: 1px solid #2d4a6b;">
  <table class="w-full">
    <thead>
      <tr style="border-bottom: 1px solid #2d4a6b;">
        <th class="px-4 py-3 text-left text-sm font-medium" style="color: #94a3b8;">Nome</th>
        <th class="px-4 py-3 text-left text-sm font-medium" style="color: #94a3b8;">Padrão</th>
        <th class="px-4 py-3 text-left text-sm font-medium" style="color: #94a3b8;">Ações</th>
      </tr>
    </thead>
    <tbody>
      <% @status_chamados.each do |status| %>
        <tr style="border-bottom: 1px solid #2d4a6b;">
          <td class="px-4 py-3 text-sm" style="color: #f1f5f9;"><%= status.nome %></td>
          <td class="px-4 py-3">
            <% if status.padrao %>
              <span class="text-xs px-2 py-1 rounded-full" style="background-color: #064e3b; color: #6ee7b7;">Sim</span>
            <% else %>
              <span class="text-xs px-2 py-1 rounded-full" style="background-color: #2d4a6b; color: #94a3b8;">Não</span>
            <% end %>
          </td>
          <td class="px-4 py-3">
            <div class="flex gap-2">
              <%= link_to "Editar", edit_status_chamado_path(status),
                  class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition",
                  style: "background-color: #1e3352; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
              <%= button_to "Remover", status_chamado_path(status), method: :delete,
                  data: { turbo_confirm: "Tem certeza?" },
                  class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition cursor-pointer",
                  style: "background-color: #1e3352; border: 1px solid #ef4444; color: #ef4444;" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>