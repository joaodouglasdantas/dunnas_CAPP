<div class="max-w-2xl mx-auto">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold" style="color: #a78bfa;">Editar Usuário</h1>
    <%= link_to "Voltar", usuario_path(@usuario),
        class: "px-4 py-2 rounded-lg text-sm hover:opacity-75 transition",
        style: "background-color: #1e3352; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
  </div>

  <div class="rounded-xl p-6" style="background-color: #1a2e4a; border: 1px solid #2d4a6b;">
    <%= form_with model: @usuario, url: usuario_path(@usuario), method: :patch do |f| %>
      <% if @usuario.errors.any? %>
        <div class="px-4 py-3 rounded-lg mb-4 text-sm" style="background-color: #7f1d1d; border: 1px solid #ef4444; color: #fca5a5;">
          <ul class="list-disc list-inside">
            <% @usuario.errors.full_messages.each do |msg| %>
              <li><%= msg %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="mb-4">
        <%= f.label :nome, class: "block text-sm mb-2", style: "color: #94a3b8;" %>
        <%= f.text_field :nome, class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
      </div>
      <div class="mb-4">
        <%= f.label :email, class: "block text-sm mb-2", style: "color: #94a3b8;" %>
        <%= f.email_field :email, class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
      </div>
      <div class="mb-4">
        <%= f.label :password, "Nova senha (deixe em branco para não alterar)", class: "block text-sm mb-2", style: "color: #94a3b8;" %>
        <%= f.password_field :password, autocomplete: "off", class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
      </div>
      <div class="mb-4">
        <%= f.label :password_confirmation, "Confirmar nova senha", class: "block text-sm mb-2", style: "color: #94a3b8;" %>
        <%= f.password_field :password_confirmation, autocomplete: "off", class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
            style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
      </div>
      <% unless @usuario == current_user %>
        <div class="mb-6">
          <label class="block text-sm mb-2" style="color: #94a3b8;">Papel</label>
          <%= select_tag :papel_id,
              options_from_collection_for_select(@papeis, :id, :nome, @usuario.papeis.first&.id),
              class: "w-full rounded-lg px-3 py-2 text-sm outline-none",
              style: "background-color: #152338; border: 1px solid #2d4a6b; color: #f1f5f9;" %>
        </div>
      <% end %>

      <%= f.submit "Atualizar",
          class: "px-6 py-2 rounded-lg text-sm text-white font-medium hover:opacity-75 transition cursor-pointer",
          style: "background-color: #7c3aed; border: none;" %>
    <% end %>
  </div>
</div>