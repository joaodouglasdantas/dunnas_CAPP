<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold" style="color: var(--purple-light);">Usuários</h1>
  <%= link_to "Novo Usuário", new_usuario_path,
      class: "px-4 py-2 rounded-lg text-sm text-white font-medium hover:opacity-75 transition",
      style: "background-color: var(--purple);" %>
</div>

<div class="rounded-xl overflow-hidden" style="background-color: var(--bg-card); border: 1px solid var(--border);">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr style="border-bottom: 1px solid var(--border);">
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Nome</th>
          <th class="px-4 py-3 text-left text-sm font-medium hidden md:table-cell" style="color: var(--text-muted);">Email</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Papel</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% @usuarios.each do |usuario| %>
          <tr style="border-bottom: 1px solid var(--border);">
            <td class="px-4 py-3 text-sm" style="color: var(--text);"><%= usuario.nome %></td>
            <td class="px-4 py-3 text-sm hidden md:table-cell" style="color: var(--text-muted);"><%= usuario.email %></td>
            <td class="px-4 py-3">
              <span class="text-xs px-2 py-1 rounded-full" style="background-color: var(--status-bg); color: var(--status-text);"><%= usuario.papeis.map(&:nome).join(", ") %></span>
            </td>
            <td class="px-4 py-3">
              <div class="flex gap-2">
                <%= link_to "Ver", usuario_path(usuario),
                    class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition",
                    style: "background-color: var(--bg-row); border: 1px solid var(--border); color: var(--text);" %>
                <%= link_to "Editar", edit_usuario_path(usuario),
                  class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition",
                  style: "background-color: var(--bg-row); border: 1px solid var(--purple-light); color: var(--purple-light);" %>
                <% unless usuario == current_user %>
                  <%= button_to "Remover", usuario_path(usuario), method: :delete,
                      data: { turbo_confirm: "Tem certeza?" },
                      class: "text-xs px-3 py-1 rounded-lg hover:opacity-75 transition cursor-pointer",
                      style: "background-color: var(--bg-row); border: 1px solid var(--danger); color: var(--danger);" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>