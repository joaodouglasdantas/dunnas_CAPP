<h1 class="text-2xl font-bold mb-6" style="color: var(--purple-light);">Auditoria do Sistema</h1>

<div class="rounded-xl overflow-hidden" style="background-color: var(--bg-card); border: 1px solid var(--border);">
  <div class="overflow-x-auto">
    <table class="w-full">
      <thead>
        <tr style="border-bottom: 1px solid var(--border);">
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Data/Hora</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Usuário</th>
          <th class="px-4 py-3 text-left text-sm font-medium" style="color: var(--text-muted);">Ação</th>
        </tr>
      </thead>
      <tbody>
        <% @logs.each do |log| %>
          <tr style="border-bottom: 1px solid var(--border);">
            <td class="px-4 py-3 text-sm whitespace-nowrap" style="color: var(--text-muted);"><%= log.created_at.strftime("%d/%m/%Y %H:%M") %></td>
            <td class="px-4 py-3 text-sm whitespace-nowrap" style="color: var(--purple-light);"><%= log.usuario&.nome || "Sistema" %></td>
            <td class="px-4 py-3 text-sm"
                title="<%= log.acao %>"
                style="color: var(--text); max-width: 600px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; cursor: help;">
              <%= log.acao %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>