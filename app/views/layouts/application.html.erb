<!DOCTYPE html>
<html data-theme="dark">
  <head>
    <title>Capp</title>
    <%= favicon_link_tag asset_path('favicon.svg'), type: 'image/svg+xml' %>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "theme", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <script>
      (function() {
        var t = localStorage.getItem('capp-theme') || 'dark';
        document.documentElement.setAttribute('data-theme', t);
      })();
    </script>
  </head>
  <body class="min-h-screen" style="background-color: var(--bg-page); color: var(--text);">

    <% if user_signed_in? %>
      <nav class="fixed top-0 left-0 right-0 z-50" style="background-color: var(--bg-card); border-bottom: 1px solid var(--border);">
        <div class="w-full px-4 md:px-8 py-3 flex items-center justify-between">
          <%= link_to dashboard_path, class: "no-underline flex items-center" do %>
            <%= render "shared/logo_navbar" %>
          <% end %>

          <span class="hidden md:block text-sm" style="color: var(--text-muted);">Olá, <%= current_user.nome %></span>

          <div class="hidden md:flex items-center gap-3 text-sm">
            <% if current_user.administrador? %>
              <%= link_to "Blocos", blocos_path, class: "hover:opacity-75 transition", style: "color: var(--text);" %>
              <%= link_to "Usuários", usuarios_path, class: "hover:opacity-75 transition", style: "color: var(--text);" %>
              <%= link_to "Chamados", chamados_path, class: "hover:opacity-75 transition", style: "color: var(--text);" %>
              <%= link_to "Tipos", tipos_chamado_index_path, class: "hover:opacity-75 transition", style: "color: var(--text);" %>
              <%= link_to "Status", status_chamados_path, class: "hover:opacity-75 transition", style: "color: var(--text);" %>
              <%= link_to "Auditoria", logs_auditoria_path, class: "hover:opacity-75 transition", style: "color: var(--text);" %>
            <% elsif current_user.colaborador? %>
              <%= link_to "Chamados", chamados_path, class: "hover:opacity-75 transition", style: "color: var(--text);" %>
            <% elsif current_user.morador? %>
              <%= link_to "Meus Chamados", chamados_path, class: "hover:opacity-75 transition", style: "color: var(--text);" %>
              <%= link_to "Abrir Chamado", new_chamado_path, class: "hover:opacity-75 transition", style: "color: var(--text);" %>
            <% end %>

            <button id="theme-toggle" onclick="toggleTheme()" title="Alternar tema"
                class="flex items-center justify-center w-8 h-8 rounded-lg hover:opacity-75 transition"
                style="background-color: var(--bg-row); border: 1px solid var(--border);">
              <span id="theme-icon">🌙</span>
            </button>

            <%= link_to "Sair", destroy_user_session_path, method: :get,
                class: "px-3 py-1 rounded text-white text-sm font-medium hover:opacity-75 transition",
                style: "background-color: var(--purple);" %>
          </div>

          <div class="flex items-center gap-2 md:hidden">
            <button onclick="toggleTheme()" title="Alternar tema"
                class="flex items-center justify-center w-8 h-8 rounded-lg hover:opacity-75 transition"
                style="background-color: var(--bg-row); border: 1px solid var(--border);">
              <span class="theme-icon-mobile">🌙</span>
            </button>
            <button id="menu-toggle" class="flex flex-col gap-1.5 p-2" onclick="toggleMenu()">
              <span class="block w-6 h-0.5" style="background-color: var(--text);"></span>
              <span class="block w-6 h-0.5" style="background-color: var(--text);"></span>
              <span class="block w-6 h-0.5" style="background-color: var(--text);"></span>
            </button>
          </div>
        </div>

        <div id="mobile-menu" class="hidden md:hidden px-4 pb-4" style="border-top: 1px solid var(--border);">
          <p class="text-sm py-3" style="color: var(--text-muted);">Olá, <%= current_user.nome %></p>
          <div class="flex flex-col gap-2">
            <% if current_user.administrador? %>
              <%= link_to "Blocos", blocos_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: var(--text); background-color: var(--bg-row);" %>
              <%= link_to "Usuários", usuarios_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: var(--text); background-color: var(--bg-row);" %>
              <%= link_to "Chamados", chamados_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: var(--text); background-color: var(--bg-row);" %>
              <%= link_to "Tipos de Chamado", tipos_chamado_index_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: var(--text); background-color: var(--bg-row);" %>
              <%= link_to "Status", status_chamados_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: var(--text); background-color: var(--bg-row);" %>
              <%= link_to "Auditoria", logs_auditoria_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: var(--text); background-color: var(--bg-row);" %>
            <% elsif current_user.colaborador? %>
              <%= link_to "Chamados", chamados_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: var(--text); background-color: var(--bg-row);" %>
            <% elsif current_user.morador? %>
              <%= link_to "Meus Chamados", chamados_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: var(--text); background-color: var(--bg-row);" %>
              <%= link_to "Abrir Chamado", new_chamado_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: var(--text); background-color: var(--bg-row);" %>
            <% end %>
            <%= link_to "Sair", destroy_user_session_path, method: :get,
                class: "text-sm py-2 px-3 rounded-lg text-white font-medium hover:opacity-75",
                style: "background-color: var(--purple);" %>
          </div>
        </div>
      </nav>

      <script>
        function toggleMenu() {
          const menu = document.getElementById('mobile-menu');
          menu.classList.toggle('hidden');
        }

        function toggleTheme() {
          const html = document.documentElement;
          const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
          html.setAttribute('data-theme', next);
          localStorage.setItem('capp-theme', next);
          updateThemeIcons(next);
        }

        function updateThemeIcons(theme) {
          const emoji = theme === 'dark' ? '🌙' : '☀️';
          const icon = document.getElementById('theme-icon');
          if (icon) icon.textContent = emoji;
          document.querySelectorAll('.theme-icon-mobile').forEach(el => el.textContent = emoji);
        }

        document.addEventListener('DOMContentLoaded', function() {
          const saved = localStorage.getItem('capp-theme') || 'dark';
          updateThemeIcons(saved);
        });
      </script>

      <div class="w-full mx-auto px-4 md:px-8" style="padding-top: 80px; padding-bottom: 24px;">
        <% if notice %>
          <div class="px-4 py-3 rounded mb-4 text-sm" style="background-color: var(--success-bg); border: 1px solid var(--success-border); color: var(--success-text);">
            <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div class="px-4 py-3 rounded mb-4 text-sm" style="background-color: var(--error-bg); border: 1px solid var(--danger); color: var(--error-text);">
            <%= alert %>
          </div>
        <% end %>
        <%= yield %>
      </div>

    <% else %>
      <% if notice %>
        <div class="fixed top-4 left-1/2 -translate-x-1/2 px-4 py-3 rounded z-50 text-sm" style="background-color: var(--success-bg); border: 1px solid var(--success-border); color: var(--success-text);">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="fixed top-4 left-1/2 -translate-x-1/2 px-4 py-3 rounded z-50 text-sm" style="background-color: var(--error-bg); border: 1px solid var(--danger); color: var(--error-text);">
          <%= alert %>
        </div>
      <% end %>
      <%= yield %>
    <% end %>

  </body>
</html>