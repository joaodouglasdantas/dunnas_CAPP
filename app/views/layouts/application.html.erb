<!DOCTYPE html>
<html>
  <head>
    <title>Capp</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>
  <body class="min-h-screen" style="background-color: #152338; color: #f1f5f9;">

    <% if user_signed_in? %>
      <nav class="fixed top-0 left-0 right-0 z-50" style="background-color: #1a2e4a; border-bottom: 1px solid #2d4a6b;">
        <div class="w-full px-4 md:px-8 py-3 flex items-center justify-between">
          <%= link_to "Capp", dashboard_path, class: "font-bold text-lg no-underline", style: "color: #a78bfa;" %>

          <span class="hidden md:block text-sm" style="color: #94a3b8;">Olá, <%= current_user.nome %></span>

          <div class="hidden md:flex items-center gap-3 text-sm">
            <% if current_user.administrador? %>
              <%= link_to "Blocos", blocos_path, class: "hover:opacity-75 transition", style: "color: #f1f5f9;" %>
              <%= link_to "Usuários", usuarios_path, class: "hover:opacity-75 transition", style: "color: #f1f5f9;" %>
              <%= link_to "Chamados", chamados_path, class: "hover:opacity-75 transition", style: "color: #f1f5f9;" %>
              <%= link_to "Tipos", tipos_chamado_index_path, class: "hover:opacity-75 transition", style: "color: #f1f5f9;" %>
              <%= link_to "Status", status_chamados_path, class: "hover:opacity-75 transition", style: "color: #f1f5f9;" %>
              <%= link_to "Auditoria", logs_auditoria_path, class: "hover:opacity-75 transition", style: "color: #f1f5f9;" %>
            <% elsif current_user.colaborador? %>
              <%= link_to "Chamados", chamados_path, class: "hover:opacity-75 transition", style: "color: #f1f5f9;" %>
            <% elsif current_user.morador? %>
              <%= link_to "Meus Chamados", chamados_path, class: "hover:opacity-75 transition", style: "color: #f1f5f9;" %>
              <%= link_to "Abrir Chamado", new_chamado_path, class: "hover:opacity-75 transition", style: "color: #f1f5f9;" %>
            <% end %>
            <%= link_to "Sair", destroy_user_session_path, method: :get,
                class: "px-3 py-1 rounded text-white text-sm font-medium hover:opacity-75 transition",
                style: "background-color: #7c3aed;" %>
          </div>

          <button id="menu-toggle" class="md:hidden flex flex-col gap-1.5 p-2" onclick="toggleMenu()">
            <span class="block w-6 h-0.5" style="background-color: #f1f5f9;"></span>
            <span class="block w-6 h-0.5" style="background-color: #f1f5f9;"></span>
            <span class="block w-6 h-0.5" style="background-color: #f1f5f9;"></span>
          </button>
        </div>

        <div id="mobile-menu" class="hidden md:hidden px-4 pb-4" style="border-top: 1px solid #2d4a6b;">
          <p class="text-sm py-3" style="color: #94a3b8;">Olá, <%= current_user.nome %></p>
          <div class="flex flex-col gap-2">
            <% if current_user.administrador? %>
              <%= link_to "Blocos", blocos_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: #f1f5f9; background-color: #1e3352;" %>
              <%= link_to "Usuários", usuarios_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: #f1f5f9; background-color: #1e3352;" %>
              <%= link_to "Chamados", chamados_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: #f1f5f9; background-color: #1e3352;" %>
              <%= link_to "Tipos de Chamado", tipos_chamado_index_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: #f1f5f9; background-color: #1e3352;" %>
              <%= link_to "Status", status_chamados_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: #f1f5f9; background-color: #1e3352;" %>
              <%= link_to "Auditoria", logs_auditoria_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: #f1f5f9; background-color: #1e3352;" %>
            <% elsif current_user.colaborador? %>
              <%= link_to "Chamados", chamados_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: #f1f5f9; background-color: #1e3352;" %>
            <% elsif current_user.morador? %>
              <%= link_to "Meus Chamados", chamados_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: #f1f5f9; background-color: #1e3352;" %>
              <%= link_to "Abrir Chamado", new_chamado_path, class: "text-sm py-2 px-3 rounded-lg hover:opacity-75", style: "color: #f1f5f9; background-color: #1e3352;" %>
            <% end %>
            <%= link_to "Sair", destroy_user_session_path, method: :get,
                class: "text-sm py-2 px-3 rounded-lg text-white font-medium hover:opacity-75",
                style: "background-color: #7c3aed;" %>
          </div>
        </div>
      </nav>

      <script>
        function toggleMenu() {
          const menu = document.getElementById('mobile-menu');
          menu.classList.toggle('hidden');
        }
      </script>

      <div class="w-full max-w-7xl mx-auto px-4 md:px-8" style="padding-top: 80px; padding-bottom: 24px;">
        <% if notice %>
          <div class="px-4 py-3 rounded mb-4 text-sm" style="background-color: #064e3b; border: 1px solid #10b981; color: #6ee7b7;">
            <%= notice %>
          </div>
        <% end %>
        <% if alert %>
          <div class="px-4 py-3 rounded mb-4 text-sm" style="background-color: #7f1d1d; border: 1px solid #ef4444; color: #fca5a5;">
            <%= alert %>
          </div>
        <% end %>
        <%= yield %>
      </div>

    <% else %>
      <% if notice %>
        <div class="fixed top-4 left-1/2 -translate-x-1/2 px-4 py-3 rounded z-50 text-sm" style="background-color: #064e3b; border: 1px solid #10b981; color: #6ee7b7;">
          <%= notice %>
        </div>
      <% end %>
      <% if alert %>
        <div class="fixed top-4 left-1/2 -translate-x-1/2 px-4 py-3 rounded z-50 text-sm" style="background-color: #7f1d1d; border: 1px solid #ef4444; color: #fca5a5;">
          <%= alert %>
        </div>
      <% end %>
      <%= yield %>
    <% end %>

  </body>
</html>